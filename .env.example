DB_PORT=5432
BACKEND_PORT=8001
FRONTEND_PORT=5173

POSTGRES_DB=smart_budget_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/smart_budget_db
CORS_ORIGINS=http://localhost:5173
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?$
MODEL_PATH=app/ml/ml_model.pkl
ENVIRONMENT=development
AUTH_REQUIRED=true
JWT_SECRET_KEY=dev-insecure-secret
JWT_ALGORITHM=HS256
DEFAULT_USER_ID=1
AI_RATE_LIMIT_PER_MINUTE=30
VITE_API_BASE_URL=http://localhost:8001/api
